rules_version = '2';

// Photo-mode queue: each signed-in user (the shared family account) may
// read/write only their own photos folder. Photos are small compressed JPEGs
// uploaded by the app and deleted by scripts/photos/process.mjs (admin SDK,
// which bypasses these rules).
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{uid}/{file} {
      allow read, write: if request.auth != null && request.auth.uid == uid
                         && (request.resource == null || request.resource.size < 3 * 1024 * 1024);
    }
  }
}
